# App
NODE_ENV=production
PORT=3000

# Insforge Database (external — already connected)
DB_HOST=your-insforge-host
DB_PORT=5432
DB_NAME=your-db-name
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_SSL=true

# SMTP (ZSM eServices)
SMTP_HOST=mail.zsmeservices.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_ENCRYPTION=SSL/TLS
SMTP_USER=tanmoy.mondal@zsmeservices.com
SMTP_PASSWORD=your-smtp-password

# IMAP (if your app also reads mail, e.g. OTP inbox monitoring)
IMAP_HOST=mail.zsmeservices.com
IMAP_PORT=993

# Webmail / branding
WEBMAIL_URL=https://mail.zsmeservices.com/webmail
DEFAULT_FROM_NAME=ZSM Services
DEFAULT_FROM_EMAIL=tanmoy.mondal@zsmeservices.com